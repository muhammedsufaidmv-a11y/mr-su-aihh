{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "businessName": { "type": "string" },
        "businessNiche": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "MarketingStrategy": {
      "title": "Marketing Strategy",
      "description": "A marketing strategy plan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "goals": { "type": "string" },
        "targetAudience": { "type": "string" },
        "strategy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "strategy"]
    },
    "ContentItem": {
      "title": "Content Item",
      "description": "A piece of content (post, blog, etc.)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["instagram", "linkedin", "facebook", "tiktok", "blog"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "closed", "lost"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "Task": {
      "title": "Task",
      "description": "A team task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assignedTo": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat conversation",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content"]
    },
    "MarketingResult": {
      "title": "Marketing Result",
      "description": "A result generated by an AI tool",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "topic": { "type": "string" },
        "platform": { "type": "string" },
        "business": { "type": "string" },
        "service": { "type": "string" },
        "audience": { "type": "string" }
      },
      "required": ["type", "content"]
    },
    "SavedPrompt": {
      "title": "Saved Prompt",
      "description": "A prompt saved by the user for reuse",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/strategies/{strategyId}": {
      "schema": "MarketingStrategy",
      "description": "Marketing strategies per user"
    },
    "/users/{userId}/content/{contentId}": {
      "schema": "ContentItem",
      "description": "Content items per user"
    },
    "/users/{userId}/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads per user"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks per user"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history per user"
    },
    "/users/{userId}/results/{resultId}": {
      "schema": "MarketingResult",
      "description": "AI generated marketing results"
    },
    "/users/{userId}/saved_prompts/{promptId}": {
      "schema": "SavedPrompt",
      "description": "Saved prompts per user"
    }
  }
}
