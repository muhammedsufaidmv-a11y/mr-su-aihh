rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, businessName, businessNiche, createdAt
    //
    // Collection: users/{userId}/strategies
    // Fields: userId, title, goals, targetAudience, strategy, createdAt
    //
    // Collection: users/{userId}/content
    // Fields: userId, type, title, content, hashtags, scheduledDate, status, createdAt
    //
    // Collection: users/{userId}/leads
    // Fields: userId, name, email, source, status, notes, createdAt
    //
    // Collection: users/{userId}/tasks
    // Fields: userId, assignedTo, title, description, priority, status, dueDate, createdAt
    //
    // Collection: users/{userId}/messages
    // Fields: role, content, images, createdAt
    //
    // Collection: users/{userId}/results
    // Fields: type, content, timestamp, topic, platform, business, service, audience
    //
    // Collection: users/{userId}/saved_prompts
    // Fields: title, content, category, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidStrategy(data) {
      return data.keys().hasAll(['userId', 'title', 'strategy']) &&
             data.userId == request.auth.uid;
    }

    function isValidContent(data) {
      return data.keys().hasAll(['userId', 'content']) &&
             data.userId == request.auth.uid;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title']) &&
             data.userId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content']) &&
             data.role in ['user', 'ai'] &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 10000;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['type', 'content']) &&
             data.type is string &&
             data.content is string;
    }

    function isValidSavedPrompt(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string &&
             data.content is string &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /strategies/{strategyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidStrategy(request.resource.data);
        allow update: if isOwner(userId) && isValidStrategy(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /content/{contentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidContent(request.resource.data);
        allow update: if isOwner(userId) && isValidContent(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /leads/{leadId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLead(request.resource.data);
        allow update: if isOwner(userId) && isValidLead(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(request.resource.data);
        allow update: if isOwner(userId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
        allow update: if isOwner(userId) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /results/{resultId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidResult(request.resource.data);
        allow update: if isOwner(userId) && isValidResult(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /saved_prompts/{promptId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSavedPrompt(request.resource.data);
        allow update: if isOwner(userId) && isValidSavedPrompt(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
